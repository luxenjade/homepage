{
  "name": "luxenjade-website",
  "private": true,
  "version": "2.0.0",
  "description": "Operational checks for the luxenjade-website",
  "type": "module",
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "scripts": {
    "check:js": "node scripts/check-js.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check": "pnpm run check:js && pnpm run check:links",
    "lint": "eslint .",
    "validate:data": "node scripts/validate-data.mjs",
    "test": "vitest run",
    "tree": "node scripts/tree.mjs",
    "build": "pnpm validate:data && node scripts/build.js",
    "dev": "serve dist"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.27.7",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "html-minifier-terser": "^7.2.0",
    "marked": "^18.0.5",
    "serve": "^14.2.6",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  },
  "overrides": {
    "brace-expansion": "^2.0.1"
  }
}
