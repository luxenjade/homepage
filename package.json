    "html-minifier-terser": "^7.2.0",
    "marked": "^18.0.5",
    "serve": "^14.2.6",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  },
  "overrides": {
    "brace-expansion": "^2.0.1"
  },
  "dependencies": {
    "@supabase/auth-js": "^2.108.2",
    "@supabase/functions-js": "^2.108.2",
    "@supabase/supabase-js": "^2.108.2"
  }
