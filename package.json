{
  "name": "shoei451-website",
  "private": true,
  "version": "1.0.0",
  "description": "Operational checks for the shoei451-website",
  "type": "module",
  "packageManager": "pnpm@11.1.0",
  "scripts": {
    "check:js": "node scripts/check-js.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check": "pnpm run check:js && pnpm run check:links",
    "tree": "node scripts/tree.mjs",
    "build": "node scripts/build.js",
    "dev": "serve dist"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "html-minifier-terser": "^7.2.0",
    "serve": "^14.2.6"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion": "^2.0.1"
    }
  }
}
