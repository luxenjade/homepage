# luxenjade-website — Build-time environment variables
#
# 使い方:
#   1. このファイルをコピーして .env を作る: `cp .env.example .env`
#   2. 実際の値を入れて保存 (`.env` は .gitignore 済み)
#   3. `pnpm run build` を実行すると scripts/config.js が自動で読む
#
# 値を取得する場所:
#   - SUPABASE_URL: Supabase ダッシュボード → Settings → API → Project URL
#   - SUPABASE_PUBLISHABLE_KEY: Supabase ダッシュボード → Settings → API
#     → "Publishable key" (旧 anon key)。sb_publishable_* 形式
#
# 互換性: 既存の .env で `SUPABASE_PB_KEY` を使っている場合は、
# `SUPABASE_PUBLISHABLE_KEY` に名前を変更することを推奨 (両方読める)。

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Edge Functions 側で必要な service role key はこのファイルではなく、
# Netlify ダッシュボードの Environment variables で
# `SUPABASE_SECRET_KEY` として設定してください。
# (これは config.js には読み込まれず、Deno runtime 内で直接参照される)
